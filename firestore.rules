rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Единственный администратор, управляющий контентом через веб-панель
    // (docs/index.html). Раньше запись в основные коллекции разрешалась
    // любому аутентифицированному пользователю (request.auth != null) —
    // если бы в проекте Firebase Auth была включена самостоятельная
    // регистрация, любой новый аккаунт получил бы полное право
    // писать/удалять контент всех районов. Теперь запись сверяется с тем
    // же email, что уже используется для ad_requests/banner_requests.
    function isAdmin() {
      return request.auth != null &&
          request.auth.token.email == 'ivansurmanov@yandex.ru';
    }

    // Районный админ — второй уровень доступа, заведён поверх isAdmin() без
    // custom claims (нет Admin SDK/бэкенда, значит claims выставить некому).
    // Источник истины — документ district_admins/{uid}, который создаёт
    // (и может удалить) только супер-админ через docs/index.html.
    function isDistrictAdminFor(district) {
      return request.auth != null &&
          exists(/databases/$(database)/documents/district_admins/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/district_admins/$(request.auth.uid)).data.district == district;
    }

    match /district_admins/{uid} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    match /districts/{districtId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow create: if isAdmin() || isDistrictAdminFor(request.resource.data.district);
      allow delete: if isAdmin() || isDistrictAdminFor(resource.data.district);
      allow update: if isAdmin() ||
          (isDistrictAdminFor(resource.data.district) &&
           request.resource.data.district == resource.data.district) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) &&
           request.resource.data.viewCount == resource.data.get('viewCount', 0) + 1);
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isAdmin() || (
          isDistrictAdminFor(request.resource.data.district) &&
          request.resource.data.rating == null &&
          request.resource.data.reviewCount == null);
      allow delete: if isAdmin() || isDistrictAdminFor(resource.data.district);
      // Помимо админа, разрешено анонимное обновление ТОЛЬКО агрегата
      // рейтинга (ratingSum/ratingCount), и только в пределах одного
      // голоса за запись — это самообслуживаемый счётчик, обновляемый
      // прямо с клиента транзакцией (см. OrganizationRepository.
      // submitRating), Cloud Functions в проекте нет. Та же схема, что
      // уже используется для news.viewCount/sponsored_content.clickCount:
      // грубая граница дельты вместо полной верификации — сознательный
      // компромисс для приложения без входа.
      allow update: if isAdmin() || (
          isDistrictAdminFor(resource.data.district) &&
          request.resource.data.district == resource.data.district &&
          request.resource.data.rating == resource.data.get('rating', null) &&
          request.resource.data.reviewCount == resource.data.get('reviewCount', null)
        ) || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingSum', 'ratingCount']) &&
          request.resource.data.ratingCount is int && request.resource.data.ratingSum is int &&
          request.resource.data.ratingCount >= resource.data.get('ratingCount', 0) &&
          request.resource.data.ratingCount <= resource.data.get('ratingCount', 0) + 1 &&
          request.resource.data.ratingSum >= resource.data.get('ratingSum', 0) - 4 &&
          request.resource.data.ratingSum <= resource.data.get('ratingSum', 0) + 5 &&
          request.resource.data.ratingSum >= 0);
    }

    match /organizations/{orgId}/ratings/{deviceId} {
      allow read: if true;
      // Один голос с устройства: ID документа = локальный deviceId,
      // повторная отправка перезаписывает свой же документ вместо
      // создания нового. Без auth это мягкое ограничение (сброс
      // локальных данных/переустановка = новый "голос"), тот же
      // компромисс, что и у всего проекта без логина.
      allow create, update: if request.resource.data.stars is int &&
          request.resource.data.stars >= 1 && request.resource.data.stars <= 5 &&
          request.resource.data.keys().hasOnly(['stars', 'updatedAt']);
      allow delete: if false;
    }

    // Районные админы больше не создают вакансии сами — платная подача
    // через заявку работодателя (см. vacancy_requests ниже) модерируется
    // только супер-админом, поэтому isDistrictAdminFor здесь больше не нужен.
    match /vacancies/{vacancyId} {
      allow read: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      // Публикация из заявки жителя (см. approveAdRequest в docs/index.html)
      // — единственный путь, которым районный админ создаёт объявление,
      // своя форма "Добавить объявление" ему не показывается. promotedUntil
      // обязан быть null: платное продвижение (push всем в районе) решает
      // только супер-админ, у районного админа таких заявок в очереди нет.
      allow create: if isAdmin() || (
          isDistrictAdminFor(request.resource.data.district) &&
          request.resource.data.promotedUntil == null);
      // Редактировать/удалять свои опубликованные объявления районный админ
      // может, но не может перекинуть их в другой район или задним числом
      // включить платное продвижение (promotedUntil).
      allow delete: if isAdmin() || isDistrictAdminFor(resource.data.district);
      allow update: if isAdmin() ||
          (isDistrictAdminFor(resource.data.district) &&
           request.resource.data.district == resource.data.district &&
           request.resource.data.promotedUntil == resource.data.promotedUntil);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || isDistrictAdminFor(request.resource.data.district);
      allow delete: if isAdmin() || isDistrictAdminFor(resource.data.district);
      allow update: if isAdmin() ||
          (isDistrictAdminFor(resource.data.district) &&
           request.resource.data.district == resource.data.district);
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      // "Прочитано" хранится только локально на устройстве клиента (см.
      // LocalStorageService.markNotificationsSeen) — общего изменяемого
      // поля isRead на документе больше нет, клиенту не нужно ничего
      // обновлять здесь. Раньше разрешённое обновление isRead было доступно
      // без аутентификации и мгновенно "прочитывало" уведомление у всех
      // жителей района одновременно, стоило одному открыть его.
    }

    match /bus_routes/{routeId} {
      allow read: if true;
      allow create: if isAdmin() || isDistrictAdminFor(request.resource.data.district);
      allow delete: if isAdmin() || isDistrictAdminFor(resource.data.district);
      allow update: if isAdmin() ||
          (isDistrictAdminFor(resource.data.district) &&
           request.resource.data.district == resource.data.district);
    }

    match /sponsored_content/{sponsoredId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount', 'lastClickedAt']) &&
           request.resource.data.clickCount == resource.data.get('clickCount', 0) + 1);
    }

    // Общеплатформенный раздел "Полезное" (партнёрские офферы — карты,
    // страховки, займы и т.п.) — без привязки к району, виден всем жителям
    // независимо от выбранного района. В отличие от новостей/объявлений/
    // вакансий районные админы к нему доступа не имеют вообще — управляет
    // только супер-админ.
    match /useful_offers/{offerId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Анонимный инкремент clickCount при тапе по офферу — та же схема,
      // что и у sponsored_content.clickCount выше: показывается в
      // супер-админке как метрика популярности, без полноценной аналитики.
      allow update: if isAdmin() ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount']) &&
           request.resource.data.clickCount == resource.data.get('clickCount', 0) + 1);
    }

    // Счётчики "сколько устройств сейчас подписано на опциональную
    // push-категорию" (события/вакансии/бесплатные объявления/"Полезное" —
    // см. NotificationPreferences во Flutter-приложении) — единственный
    // способ увидеть в супер-админке эффект от фичи, чьё реальное состояние
    // (SharedPreferences) иначе никогда не попадает в Firestore. Один
    // документ на категорию (id = 'events'|'vacancies'|'free_announcements'|
    // 'useful_offers'), поле count меняется ровно на ±1 за раз — та же
    // "грубая граница дельты" что и у sponsored_content.clickCount, только
    // с обеих сторон (включение/выключение), а не только вверх.
    match /analytics_push_opt_ins/{categoryId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count']) &&
          request.resource.data.count is int &&
          request.resource.data.count >= 0 &&
          (request.resource.data.count == resource.data.get('count', 0) + 1 ||
           request.resource.data.count == resource.data.get('count', 0) - 1)
        );
    }

    match /ad_requests/{requestId} {
      // Районный админ видит и модерирует только БЕСПЛАТНЫЕ заявки своего
      // района (wantsPush == false) — платные (заказан push-охват района)
      // всегда проходят только через супер-админа, оплату вручную сверяет
      // только он. Для list-запросов Firestore требует, чтобы условие
      // резолвилось из фильтров самого запроса (см. loadAdRequests —
      // добавляет .where('wantsPush','==',false) для районного админа),
      // иначе весь запрос будет отклонён целиком, а не просто отфильтрован.
      allow read: if isAdmin() ||
          (isDistrictAdminFor(resource.data.district) && resource.data.wantsPush == false);
      allow create: if request.resource.data.title is string &&
          request.resource.data.title.size() > 0 && request.resource.data.title.size() < 200 &&
          request.resource.data.description is string &&
          request.resource.data.description.size() < 3000 &&
          request.resource.data.phone is string &&
          request.resource.data.wantsPush is bool &&
          request.resource.data.status == 'pending' &&
          request.resource.data.district is string &&
          (!('images' in request.resource.data) ||
           (request.resource.data.images is list && request.resource.data.images.size() <= 5)) &&
          (request.resource.data.wantsPush == false ||
           (request.resource.data.durationDays in [7, 14, 30] &&
            request.resource.data.price is int && request.resource.data.price > 0));
      // Районному админу доступны два вида правок бесплатной заявки своего
      // района, но не одновременно: смена статуса (публикация/удаление)
      // ИЛИ правка текста, пока заявка ещё pending. Район и wantsPush
      // менять нельзя в обоих случаях — это заблокировало бы, например,
      // попытку "перекрасить" платную заявку в бесплатную для себя.
      allow update: if isAdmin() || (
          isDistrictAdminFor(resource.data.district) &&
          resource.data.wantsPush == false &&
          request.resource.data.wantsPush == false &&
          request.resource.data.district == resource.data.district &&
          (
            (resource.data.status == 'pending' &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
             request.resource.data.status in ['approved', 'rejected']) ||
            (resource.data.status == 'pending' &&
             request.resource.data.status == 'pending' &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'phone', 'images']))
          )
        );
      allow delete: if false;
    }

    // Служебные настройки веб-панели (например, точка сброса счётчика
    // статистики объявлений в docs/index.html) — только супер-админ.
    match /app_settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Фиче-флаги, включающие/выключающие для жителей опции подачи (платное
    // продвижение объявлений с push, приём баннеров от жителей) — в отличие
    // от app_settings выше, читать должно само приложение без входа в
    // систему, поэтому чтение открыто всем. Меняет только супер-админ.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banner_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.title is string &&
          request.resource.data.title.size() > 0 && request.resource.data.title.size() < 200 &&
          request.resource.data.imageUrl is string &&
          request.resource.data.imageUrl.size() > 0 && request.resource.data.imageUrl.size() < 500 &&
          request.resource.data.targetUrl is string &&
          request.resource.data.targetUrl.size() > 0 && request.resource.data.targetUrl.size() < 500 &&
          request.resource.data.phone is string &&
          request.resource.data.durationDays in [7, 14, 30] &&
          request.resource.data.price is int && request.resource.data.price > 0 &&
          request.resource.data.status == 'pending' &&
          request.resource.data.district is string;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Заявки работодателей на публикацию вакансии — видит и модерирует
    // ТОЛЬКО супер-админ, сразу со всех районов (в отличие от ad_requests,
    // где районный админ видит бесплатные заявки своего района). Цена
    // фиксированная (см. VacancyRequestPricing), поэтому здесь нет полей
    // durationDays/wantsPush, как у banner_requests/ad_requests.
    match /vacancy_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.title is string &&
          request.resource.data.title.size() > 0 && request.resource.data.title.size() < 200 &&
          request.resource.data.company is string &&
          request.resource.data.company.size() > 0 && request.resource.data.company.size() < 200 &&
          request.resource.data.description is string &&
          request.resource.data.description.size() < 3000 &&
          request.resource.data.phone is string &&
          request.resource.data.price is int && request.resource.data.price > 0 &&
          request.resource.data.status == 'pending' &&
          request.resource.data.district is string &&
          (!('salary' in request.resource.data) ||
           request.resource.data.salary == null ||
           (request.resource.data.salary is string && request.resource.data.salary.size() < 100));
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Обращения к супер-администратору (вопросы по сотрудничеству, работе
    // приложения, пожелания) — формат чата, переписка продолжается по
    // одному и тому же документу. В отличие от banner_requests/
    // vacancy_requests выше (allow read: if isAdmin()), автору обращения без
    // входа в приложение тоже нужно прочитать СВОЙ документ — иначе он не
    // увидит ответ. get и list разделены намеренно: get разрешён всем
    // (документ читается по известному ID, сохранённому на устройстве при
    // отправке — Firestore auto-ID не перечислим и не угадаем, тот же
    // компромисс, что и у deviceId в organizations/{orgId}/ratings), а list
    // (просмотр/перечисление всех обращений сразу) — только супер-админу.
    match /feedback_requests/{requestId} {
      allow get: if true;
      allow list: if isAdmin();
      // messages — переписка по обращению (см. FeedbackRequestModel):
      // [{sender:'resident'|'admin', text, createdAt}]. При создании в
      // массиве ровно одно сообщение от жителя.
      allow create: if request.resource.data.district is string &&
          request.resource.data.deviceId is string &&
          request.resource.data.deviceId.size() > 0 &&
          request.resource.data.status == 'pending' &&
          request.resource.data.messages is list &&
          request.resource.data.messages.size() == 1 &&
          request.resource.data.messages[0].sender == 'resident' &&
          request.resource.data.messages[0].text is string &&
          request.resource.data.messages[0].text.size() > 0 &&
          request.resource.data.messages[0].text.size() < 2000 &&
          (!('phone' in request.resource.data) ||
           request.resource.data.phone == null ||
           (request.resource.data.phone is string && request.resource.data.phone.size() < 30));
      // Супер-админ отвечает/удаляет без ограничений. Житель (не аутентифи-
      // цирован — тот же компромисс "ID известен = как бы токен", что и у
      // get выше) может ТОЛЬКО дописать одно своё сообщение в конец chatа:
      // messages.size() растёт ровно на 1 через arrayUnion (Firestore не
      // даёт arrayUnion переписать/удалить существующие элементы — поэтому
      // прошлые сообщения, в т.ч. ответы админа, гарантированно нельзя
      // подделать этим правилом), новое сообщение — обязательно
      // sender:'resident', и после дописывания status снова 'pending'
      // (админ увидит, что ветка ждёт ответа).
      allow update: if isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'status', 'updatedAt']) &&
          request.resource.data.messages.size() == resource.data.messages.size() + 1 &&
          request.resource.data.messages[resource.data.messages.size()].sender == 'resident' &&
          request.resource.data.messages[resource.data.messages.size()].text is string &&
          request.resource.data.messages[resource.data.messages.size()].text.size() > 0 &&
          request.resource.data.messages[resource.data.messages.size()].text.size() < 2000 &&
          request.resource.data.status == 'pending');
      allow delete: if isAdmin();
    }
  }
}
